{
  "name": "@nyxel/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate --config drizzle.config.pg.ts && drizzle-kit generate --config drizzle.config.sqlite.ts",
    "generate:pg": "drizzle-kit generate --config drizzle.config.pg.ts",
    "generate:sqlite": "drizzle-kit generate --config drizzle.config.sqlite.ts",
    "migrate": "bun run src/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.9.0"
  }
}
