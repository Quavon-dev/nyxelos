{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "ANTHROPIC_API_KEY",
    "DATABASE_URL",
    "LM_API_TOKEN",
    "LMSTUDIO_API_KEY",
    "LMSTUDIO_API_TOKEN",
    "LMSTUDIO_BASE_URL",
    "OPENAI_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
