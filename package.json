{
  "name": "nyxel",
  "private": true,
  "version": "0.1.0",
  "description": "NyxelOS — a self-hosted, open source agentic OS.",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "bin": {
    "nyxel": "./scripts/nyxel.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "nyxel": "bun run ./scripts/nyxel.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3"
  }
}
