# Copy to .env for local `bun run dev` (no Docker).

# "sqlite" (default, PC mode) or "pg" (server mode). See ADR-0002.
DB_DRIVER=sqlite

# SQLite: a file path. Postgres: a postgres:// connection string.
DATABASE_URL=./nyxel.sqlite

PORT=3001
# The value below is a well-known public placeholder, not a real secret — it
# is only safe for a server that's never reachable beyond 127.0.0.1. Generate
# a real one before running anywhere else (openssl rand -base64 32); see
# docs/DEPLOYMENT_HARDENING.md. Production refuses to start with this value.
BETTER_AUTH_SECRET=dev-secret-change-me
BETTER_AUTH_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# Encrypts secret-shaped DB columns at rest (model provider API keys,
# Obsidian REST key — see packages/db/src/crypto.ts). Same rules as
# BETTER_AUTH_SECRET above: this placeholder is only safe on 127.0.0.1,
# generate a real one (openssl rand -base64 32) for anything else, and never
# reuse BETTER_AUTH_SECRET's value here — different secret, different
# rotation lifecycle. Production refuses to start with this value.
NYXEL_ENCRYPTION_KEY=dev-encryption-key-change-me

# Local model runtimes — defaults assume they're running on the same
# machine. Only needed if you've moved them elsewhere.
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234

# Optional — enables Anthropic cloud models in the model picker.
ANTHROPIC_API_KEY=

# Both default to enabled in dev, disabled in production (NODE_ENV=production)
# — installed plugin code and custom-code skills run in the main server
# process with no sandboxing beyond a scoped fetch/fs context (see
# docs/PLUGIN_SECURITY.md). Set to "true" to opt back in for a production
# deployment that specifically needs one of these, after reading that doc.
# ENABLE_REMOTE_PLUGIN_INSTALL=true
# ENABLE_CUSTOM_CODE_SKILLS=true

# Optional — enables Web Push notifications that survive a server restart.
# Without these, apps/server/src/push.ts generates a throwaway key pair every
# boot and logs it to stdout; every existing push subscription then breaks on
# the next restart. Generate once with: bunx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@nyxel.local
