# Used by BOTH docker-compose.pc.yml and docker-compose.server.yml — Docker
# Compose auto-loads a root .env regardless of which compose file you pass
# via -f. For local dev without Docker, see apps/server/.env.example and
# apps/web/.env.example instead.

# Server mode only — the domain Caddy requests a TLS certificate for.
NYXEL_DOMAIN=nyxel.example.com

# Optional but recommended in server mode — email address used for ACME account
# registration / certificate management in Caddy.
ACME_EMAIL=ops@example.com

# Server mode only — Postgres password (also used inside DATABASE_URL).
POSTGRES_PASSWORD=change-me

# Required in both modes — used to sign Better-Auth session tokens. If left
# unset, docker-compose.pc.yml silently falls back to the well-known public
# value "dev-secret-change-me" instead of refusing to start — safe only for
# an instance that never leaves 127.0.0.1. See docs/DEPLOYMENT_HARDENING.md.
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# Optional — enables Anthropic cloud models in the model picker.
ANTHROPIC_API_KEY=
