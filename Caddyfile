{$NYXEL_DOMAIN:localhost} {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options SAMEORIGIN
	}

	@health path /healthz
	handle @health {
		respond "ok" 200
	}

	@api path /trpc/* /api/*
	handle @api {
		reverse_proxy server:3001
	}

	handle {
		reverse_proxy web:3000
	}
}
