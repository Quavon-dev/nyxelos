{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "web",
      "runtimeExecutable": "bunx",
      "runtimeArgs": ["next", "dev", "--turbopack", "-p", "4100"],
      "cwd": "apps/web",
      "port": 4100,
      "autoPort": false
    },
    {
      "name": "server",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--hot", "src/index.ts"],
      "cwd": "apps/server",
      "port": 4001,
      "autoPort": false
    }
  ]
}
