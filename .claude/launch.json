{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "web",
      "runtimeExecutable": "bunx",
      "runtimeArgs": ["next", "dev", "--turbopack"],
      "cwd": "apps/web",
      "port": 3100,
      "autoPort": true
    },
    {
      "name": "server",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--hot", "src/index.ts"],
      "cwd": "apps/server",
      "port": 3001,
      "autoPort": true
    }
  ]
}
